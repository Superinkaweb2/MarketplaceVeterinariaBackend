			<text><![CDATA[FIRMA DEL PROVEEDOR]]></text>
		</element>
		<element kind="staticText" uuid="bd7d17a9-1549-48fc-8eac-995f42eb7069" x="0" y="700" width="70" height="30" fontName="Arial" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<text><![CDATA[¹RECLAMO:]]></text>
