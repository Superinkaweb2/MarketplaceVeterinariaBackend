		<element kind="staticText" uuid="05e9b29c-c457-407d-81af-60cc75487cca" x="0" y="753" width="550" height="10" fontName="Arial" fontSize="7.5" hTextAlign="Left" vTextAlign="Middle">
			<text><![CDATA[* La formulación del reclamo no impide acudir a otras vías de solución de controversias ni es requisito previo para interponer una denuncia ante el INDECOPI. ]]></text>
		</element>
		<element kind="staticText" uuid="3e0fc382-0fd2-48f6-94c8-d65e0762132d" x="0" y="764" width="550" height="10" fontName="Arial" fontSize="7.5" hTextAlign="Left" vTextAlign="Middle">
			<text><![CDATA[* El proveedor debe dar respuesta al reclamo o queja en un plazo no mayor a quince (15) días hábiles, el cual es improrrogable.]]></text>
		</element>
		<element kind="staticText" uuid="c54af96d-1604-4148-b282-8d3f1353a56b" x="0" y="730" width="550" height="20" fontName="Arial" bold="true" hTextAlign="Right" vTextAlign="Middle">
			<text><![CDATA[HOJA DE RECLAMACIÓN VIRTUAL]]></text>
		</element>
		<element kind="staticText" uuid="be2dc7f4-ddf8-4e1d-a9e9-685a4966aefa" x="280" y="540" width="270" height="30" fontName="Arial" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<text><![CDATA[FIRMA DEL CONSUMIDOR]]></text>
		</element>
