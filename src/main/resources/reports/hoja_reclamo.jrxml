			<text><![CDATA[Disconformidad relacionada a los productos o servicios.]]></text>
		</element>
		<element kind="staticText" uuid="ad254852-9713-4023-b3d3-3c8bf399de19" x="280" y="700" width="50" height="30" fontName="Arial" bold="true" hTextAlign="Center" vTextAlign="Middle">
			<text><![CDATA[²QUEJA:]]></text>
		</element>
		<element kind="staticText" uuid="9cf308de-d7a4-44d5-bb4f-68f69a988c90" x="330" y="700" width="220" height="30" fontName="Arial" fontSize="8.0" vTextAlign="Middle">
			<text><![CDATA[Disconformidad no relacionada a los productos o servicios; o, malestar o descontento respecto a la atención al público.]]></text>
		</element>
