# ============================================
# HUELLA360 - Marketplace Veterinaria Backend
# ============================================
# Copy this file to .env and fill in the values

# ---- Database ----
DB_URL=jdbc:postgresql://localhost:5432/vet_saas
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_NAME=vet_saas
DB_PORT=5432
DB_POOL_MAX=20
DB_POOL_MIN=5

# ---- Redis ----
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# ---- JWT ----
JWT_SECRET=your-256-bit-secret-at-least-32-chars
JWT_EXPIRATION=3600000
JWT_REFRESH_EXPIRATION=604800000

# ---- Auth0 ----
AUTH0_ISSUER_URI=https://your-tenant.auth0.com/
AUTH0_AUDIENCE=https://api.yourapp.com

# ---- Encryption ----
APP_ENCRYPTION_SECRET=your-32-char-encryption-key!

# ---- CORS ----
ALLOWED_ORIGINS=http://localhost:5173

# ---- App URLs ----
APP_PUBLIC_URL=http://localhost:8080
APP_BACKEND_URL=http://localhost:8080
APP_FRONTEND_URL=http://localhost:5173

# ---- MercadoPago ----
MP_ACCESS_TOKEN=your-mp-access-token
MP_CLIENT_ID=your-mp-client-id
MP_CLIENT_SECRET=your-mp-client-secret
MP_SANDBOX_BUYER_EMAIL=test@test.com
MP_SANDBOX=true
MP_WEBHOOK_SECRET=your-mp-webhook-secret

# ---- Cloudinary ----
CLOUDINARY_CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# ---- Mail (dev uses MailHog) ----
MAIL_HOST=localhost
MAIL_PORT=1025
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_FROM=test@test.com

# ---- Resend ----
RESEND_API_KEY=your-resend-api-key
RESEND_FROM=onboarding@resend.dev

# ---- API Peru ----
API_PERU_TOKEN=your-api-peru-token

# ---- Admin ----
ADMIN_EMAIL=admin@huella360.com
